# --- Version control / CI ---
.git
.github
.gitignore

# --- Secrets & credentials (NEVER in an image) ---
.env
.env.*
!.env-example
credentials.json
token.json
token.pickle
client_secret*.json
*_oauth*.json
google_oauth*.json
service_account*.json
*.key
*.pem
*.p12
secrets/
private/

# --- Python caches & build artifacts ---
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# --- Environments ---
.venv/
venv/
env/

# --- Test / coverage caches ---
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# --- Tests & local outputs (not needed in the runtime image) ---
tests/
logs/
*.log
results/

# --- Editor / OS noise ---
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Course / submission documents ---
*.pdf
*.docx
*.pptx
