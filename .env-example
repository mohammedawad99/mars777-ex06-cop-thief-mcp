# Copy to .env and fill in real values locally. NEVER commit .env.
# All values below are placeholders only.

# --- LLM provider (agents) ---
# Default is fake_local (offline, deterministic). Set to gemini to opt into the
# real Google Gemini provider; a key must be present in the environment.
LLM_PROVIDER=fake_local

# --- Optional Google Gemini provider (Stage 10; placeholders only) ---
# Provide ONE of these, set outside the repo. Never commit a real key.
GEMINI_API_KEY=<set-outside-repo>
GOOGLE_API_KEY=<optional-alternative-set-outside-repo>
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=120
GEMINI_TEMPERATURE=0.2
# Set RUN_GEMINI_LIVE=1 to enable the live Gemini smoke (off by default).
RUN_GEMINI_LIVE=0

# --- MCP servers (token auth from the start) ---
MCP_AUTH_TOKEN=generate-a-strong-random-token
MCP_COP_SERVER_URL=http://localhost:8001
MCP_THIEF_SERVER_URL=http://localhost:8002

# --- Cloud deployment packaging (Stage 13A; placeholders only, not deployed) ---
# Role selects which server the container image runs (set per service).
MCP_ROLE=<cop-or-thief>
# Cloud platforms (e.g. Cloud Run) inject PORT; PORT=8001 is a local default only.
PORT=8001
# Public URLs are filled in ONLY after a real deployment (none exists yet).
COP_MCP_PUBLIC_URL=<set-after-deployment>
THIEF_MCP_PUBLIC_URL=<set-after-deployment>
# Live deploy is a separate, manual, gated step; 0 keeps everything inert.
RUN_CLOUD_DEPLOY=0

# --- Local MCP per-role tokens & URLs (Stage 5; placeholders only) ---
COP_MCP_TOKEN=generate-a-strong-random-cop-token
THIEF_MCP_TOKEN=generate-a-strong-random-thief-token
COP_MCP_LOCAL_URL=http://127.0.0.1:8001/mcp
THIEF_MCP_LOCAL_URL=http://127.0.0.1:8002/mcp

# --- Gmail report sender (OAuth; keep files OUTSIDE the repo) ---
# Paths to OAuth desktop client secrets + token, stored outside the repo.
GOOGLE_OAUTH_CLIENT_SECRETS=/absolute/path/outside/repo/google/credentials.json
GOOGLE_OAUTH_TOKEN_PATH=/absolute/path/outside/repo/google/token.json
# Live sending is opt-in; default is dry-run. Never commit a real token.
RUN_GMAIL_LIVE=0
RUN_GMAIL_AUTH=0
GMAIL_REPORT_RECIPIENT=rmisegal+uoh26b@gmail.com

# --- Runtime ---
TIMEZONE=Asia/Jerusalem
LOG_LEVEL=INFO
