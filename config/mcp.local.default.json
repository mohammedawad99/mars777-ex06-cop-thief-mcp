{
  "version": "1.00",
  "transport": "http",
  "local_only": true,
  "auth": {
    "enabled": true
  },
  "cop_server": {
    "host": "127.0.0.1",
    "port": 8001,
    "path": "/mcp",
    "token_env_var": "COP_MCP_TOKEN"
  },
  "thief_server": {
    "host": "127.0.0.1",
    "port": 8002,
    "path": "/mcp",
    "token_env_var": "THIEF_MCP_TOKEN"
  },
  "notes": "Local-only MCP servers. No public URLs and no cloud deployment in this stage."
}
